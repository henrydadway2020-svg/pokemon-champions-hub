---
import BaseLayout from '../layouts/BaseLayout.astro';
import TournamentCard from '../components/TournamentCard.astro';
import { sampleTournaments, sampleNews } from '../data/sampleData';

// TODO: reemplazar por consulta real a D1 cuando esté conectada.
const destacados = sampleTournaments
  .filter((t) => t.estado === 'abierto' || t.estado === 'en_curso')
  .slice(0, 3);

const ultimasNoticias = sampleNews.slice(0, 3);
---

<BaseLayout title="Inicio">
  <section class="hero">
    <div class="container">
      <h1>Pokémon Champions Hub</h1>
      <p>Torneos, meta y contenido competitivo de la comunidad — todo en un solo lugar.</p>
    </div>
  </section>

  <section class="container" style="margin-top: 40px;">
    <div class="section-title">
      <h2>Torneos destacados</h2>
      <a href="/torneos">Ver todos →</a>
    </div>
    <div class="grid grid-3">
      {destacados.map((t) => <TournamentCard tournament={t} />)}
    </div>
  </section>

  <section class="container" style="margin-top: 48px;">
    <div class="section-title">
      <h2>Últimas noticias</h2>
      <a href="/noticias">Ver todas →</a>
    </div>
    <div class="grid grid-3">
      {ultimasNoticias.map((n) => (
        <a href={`/noticias/${n.slug}`} class="card news-card">
          <div class="news-card-body">
            <span class="news-category">{n.categoria}</span>
            <h3>{n.titulo}</h3>
            <p>{n.resumen}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: var(--color-primary);
    padding: 56px 0;
    color: #ffffff;
  }
  .hero h1 {
    color: #ffffff;
    font-size: 32px;
  }
  .hero p {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.9);
    max-width: 480px;
  }
  .news-card {
    color: inherit;
    text-decoration: none;
  }
  .news-card:hover {
    border-color: var(--color-primary);
    text-decoration: none;
  }
  .news-card-body {
    padding: 16px;
  }
  .news-category {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-primary);
  }
  .news-card-body h3 {
    font-size: 15px;
    margin: 6px 0;
  }
  .news-card-body p {
    font-size: 13px;
    color: var(--text-secondary);
    margin: 0;
  }
</style>
