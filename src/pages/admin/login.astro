---
import BaseLayout from '../../layouts/BaseLayout.astro';
// Con Cloudflare Access configurado sobre /admin/*, esta página normalmente
// no se ve: Access intercepta la ruta y muestra su propia pantalla de login
// antes de que la petición llegue a Astro. Se deja como referencia/fallback.
---

<BaseLayout title="Acceso administrador">
  <section class="container" style="margin-top: 64px; max-width: 400px;">
    <h1>Acceso administrador</h1>
    <p style="color: var(--text-secondary); font-size: 14px;">
      El acceso a esta sección está protegido por Cloudflare Access.
      Si ves esta página, significa que Access todavía no está configurado
      para esta ruta.
    </p>
  </section>
</BaseLayout>
