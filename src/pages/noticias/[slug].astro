---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sampleNews } from '../../data/sampleData';

// TODO: reemplazar por consulta real a D1: SELECT * FROM news WHERE slug = ?
const { slug } = Astro.params;
const noticia = sampleNews.find((n) => n.slug === slug);

if (!noticia) {
  return Astro.redirect('/noticias');
}
---

<BaseLayout title={noticia.titulo}>
  <article class="container" style="margin-top: 32px; max-width: 720px;">
    <span style="font-size:12px; font-weight:600; text-transform:uppercase; color:var(--color-primary);">
      {noticia.categoria}
    </span>
    <h1>{noticia.titulo}</h1>
    <p style="color: var(--text-secondary); font-size: 14px;">
      {new Date(noticia.fechaPublicacion).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' })}
    </p>
    <div style="margin-top: 24px; font-size: 15px;">
      <p>{noticia.contenido || noticia.resumen}</p>
    </div>
  </article>
</BaseLayout>
