---
const navItems = [
  { href: '/torneos', label: 'Torneos' },
  { href: '/noticias', label: 'Noticias' },
  { href: '/tier-list', label: 'Tier list' },
  { href: '/mas-usados', label: 'Más usados' },
  { href: '/guias', label: 'Guías' },
  { href: '/videos', label: 'Videos' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">Pokémon Champions Hub</a>
    <nav class="nav">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-navy);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    padding-bottom: 16px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .logo {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 18px;
    color: #ffffff;
  }
  .logo:hover {
    text-decoration: none;
  }
  .nav {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  .nav a {
    font-size: 14px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
  }
  .nav a:hover {
    color: #ffffff;
  }
</style>
